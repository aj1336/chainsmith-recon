# Chainsmith Recon — environment configuration
# Copy this file to .env and fill in the values for your chosen profile.
#
#   cp .env.example .env
#
# You only need ONE of the profiles below. Set LLM_PROFILE to pick which
# provider Chainsmith uses, then supply the matching key/URL.
# You can also pass --profile on the command line to override this value.

LLM_PROFILE=ollama          # openai | anthropic | ollama | litellm

# ── OpenAI (default) ────────────────────────────────────────────
# OPENAI_API_KEY=your-key-here

# ── Anthropic ───────────────────────────────────────────────────
# ANTHROPIC_API_KEY=your-key-here

# ── Ollama (local, no key required) ─────────────────────────────
OLLAMA_MODEL=mistral

# ── LiteLLM ─────────────────────────────────────────────────────
# LITELLM_BASE_URL=http://your-litellm-host:4000
# LITELLM_API_KEY=your-key-here

# ── General ─────────────────────────────────────────────────────
CHAINSMITH_PORT=8100
